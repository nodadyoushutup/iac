pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // This will check out the repo into the directory you set (terraform/proxmox)
                checkout scm
            }
        }
        stage('Debug') {
            steps {
                // Print the current directory and list files to verify where the code is
                sh 'pwd'
                sh 'ls -la'
                // Optionally list the contents of the checkout directory
                sh 'ls -la terraform/proxmox'
            }
        }
        stage('Terraform Init') {
            steps {
                // Change directory to where the .tf files are located
                dir('terraform/proxmox') {
                    echo 'Initializing Terraform...'
                    sh 'terraform init'
                }
            }
        }
        stage('Terraform Plan') {
            steps {
                dir('terraform/proxmox') {
                    withCredentials([
                        file(credentialsId: 'tfvars', variable: 'TFVARS_FILE'),
                        file(credentialsId: 'ssh_private_key', variable: 'SSH_PRIVATE_KEY')
                    ]) {
                        echo "Setting private key permissions"
                        sh "chmod 600 ${SSH_PRIVATE_KEY}"
                        
                        echo "Copying private key to workspace"
                        sh "cp ${SSH_PRIVATE_KEY} ./id_rsa"
                        
                        echo 'Running Terraform plan...'
                        sh "terraform plan -var-file=${TFVARS_FILE} -var 'SSH_PRIVATE_KEY=./id_rsa' -out=tfplan"
                    }
                }
            }
        }
        stage('Terraform Apply') {
            steps {
                dir('terraform/proxmox') {
                    echo 'Applying Terraform changes...'
                    sh 'terraform apply tfplan'
                }
            }
        }
    }
}
