global:
  scrape_interval: 5s
  evaluation_interval: 5s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ["192.168.1.101:9090"]

  - job_name: node_exporter
    static_configs:
      - targets: ["192.168.1.101:9100"]

  - job_name: cadvisor
    static_configs:
      - targets: ["192.168.1.101:8080"]

  - job_name: exportarr-sonarr
    scrape_interval: 2m
    scrape_timeout: 2m
    static_configs:
      - targets: 
        - 192.168.1.101:9707

  - job_name: exportarr-radarr
    scrape_interval: 2m
    scrape_timeout: 2m
    static_configs:
      - targets: 
        - 192.168.1.101:9708

  - job_name: exportarr-lidarr
    scrape_interval: 2m
    scrape_timeout: 2m
    static_configs:
      - targets: 
        - 192.168.1.101:9709

  - job_name: exportarr-prowlarr
    scrape_interval: 2m
    scrape_timeout: 2m
    static_configs:
      - targets: 
        - 192.168.1.101:9710
