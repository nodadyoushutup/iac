#!/bin/bash

export $(cat /.env | tr '\0' '\n' | grep -E '^NGINX_PROXY_MANAGER' | xargs)
FLAG_FILE="/tmp/custom-init-done"
RETRIES=18
DELAY=10
MYSQL_CONNECTED=false

log() {
    echo "[$(date '+%-m/%-d/%Y')] [$(date '+%-I:%M:%S %p')] [Init     ] › ℹ  info      $1"
}

check_mysql_connectivity() {
    log "Checking MySQL connectivity..."
    for (( i=1; i<=$RETRIES; i++ )); do
        if mysqladmin ping -h "${NGINX_PROXY_MANAGER_DB_HOST}" -P "${NGINX_PROXY_MANAGER_DB_PORT}" -u "${NGINX_PROXY_MANAGER_DB_USER}" -p"${NGINX_PROXY_MANAGER_DB_PASSWORD}" > /dev/null 2>&1; then
            MYSQL_CONNECTED=true
            log "MySQL connectivity established."
            return 0
        else
            log "Attempt $i/$RETRIES: MySQL not reachable. Retrying in $DELAY seconds... (host=${NGINX_PROXY_MANAGER_DB_HOST}, port=${NGINX_PROXY_MANAGER_DB_PORT}, user=${NGINX_PROXY_MANAGER_DB_USER}, password=${NGINX_PROXY_MANAGER_DB_PASSWORD})"
            sleep $DELAY
        fi
    done
    log "Failed to connect to MySQL after $RETRIES attempts."
    exit 1
}

check_table() {
    local table_name=$1
    log "Checking for '${table_name}' table..."
    for (( i=1; i<=$RETRIES; i++ )); do
        if mysql -h "${NGINX_PROXY_MANAGER_DB_HOST}" -P "${NGINX_PROXY_MANAGER_DB_PORT}" -u "${NGINX_PROXY_MANAGER_DB_USER}" -p"${NGINX_PROXY_MANAGER_DB_PASSWORD}" -D "$NGINX_PROXY_MANAGER_DB_NAME" -e "SHOW TABLES LIKE '${table_name}';" | grep -q "${table_name}"; then
            log "'${table_name}' table found."
            return 0
        else
            log "Attempt $i/$RETRIES: '${table_name}' table not found. Retrying in $DELAY seconds..."
            sleep $DELAY
        fi
    done
    log "Failed to find '${table_name}' table after $RETRIES attempts."
    exit 1
}

check_id() {
    local table_name=$1
    log "Checking for '${table_name}' table for record ID 1..."
    for (( i=1; i<=$RETRIES; i++ )); do
        if mysql -h "${NGINX_PROXY_MANAGER_DB_HOST}" -P "${NGINX_PROXY_MANAGER_DB_PORT}" -u "${NGINX_PROXY_MANAGER_DB_USER}" -p"${NGINX_PROXY_MANAGER_DB_PASSWORD}" -D "$NGINX_PROXY_MANAGER_DB_NAME" -e "SELECT COUNT(*) FROM ${table_name} WHERE id = 1;" | grep -q "1"; then
            log "'${table_name}' table record ID 1 found."
            return 0
        else
            log "Attempt $i/$RETRIES: '${table_name}' table record ID 1 not found. Retrying in $DELAY seconds..."
            sleep $DELAY
        fi
    done
    log "Failed to find '${table_name}' table record ID 1 after $RETRIES attempts."
    exit 1
}

# MAIN EXECUTION

# Check if the script has already run
if [ -f "$FLAG_FILE" ]; then
    exec sleep infinity
fi

apt update
apt install -y default-mysql-client whois

check_mysql_connectivity

if [ "$MYSQL_CONNECTED" = true ]; then
    check_table "user"
    check_id "user"

    check_table "auth"
    check_id "auth"

    # Update admin credentials
    mysql -h "${NGINX_PROXY_MANAGER_DB_HOST}" -P "${NGINX_PROXY_MANAGER_DB_PORT}" -u "${NGINX_PROXY_MANAGER_DB_USER}" -p"${NGINX_PROXY_MANAGER_DB_PASSWORD}" -D "$NGINX_PROXY_MANAGER_DB_NAME" -e "UPDATE user SET email='${NGINX_PROXY_MANAGER_AUTH_EMAIL}' WHERE id='1';"
    mysql -h "${NGINX_PROXY_MANAGER_DB_HOST}" -P "${NGINX_PROXY_MANAGER_DB_PORT}" -u "${NGINX_PROXY_MANAGER_DB_USER}" -p"${NGINX_PROXY_MANAGER_DB_PASSWORD}" -D "$NGINX_PROXY_MANAGER_DB_NAME" -e "UPDATE user SET name='$NGINX_PROXY_MANAGER_AUTH_NAME' WHERE id='1';"
    mysql -h "${NGINX_PROXY_MANAGER_DB_HOST}" -P "${NGINX_PROXY_MANAGER_DB_PORT}" -u "${NGINX_PROXY_MANAGER_DB_USER}" -p"${NGINX_PROXY_MANAGER_DB_PASSWORD}" -D "$NGINX_PROXY_MANAGER_DB_NAME" -e "UPDATE user SET nickname='$NGINX_PROXY_MANAGER_AUTH_NICKNAME' WHERE id='1';"

    # Generate bcrypt hash and update it
    SECRET=$(mkpasswd -m bcrypt "$NGINX_PROXY_MANAGER_AUTH_PASSWORD")
    mysql -h "${NGINX_PROXY_MANAGER_DB_HOST}" -P "${NGINX_PROXY_MANAGER_DB_PORT}" -u "${NGINX_PROXY_MANAGER_DB_USER}" -p"${NGINX_PROXY_MANAGER_DB_PASSWORD}" -D "$NGINX_PROXY_MANAGER_DB_NAME" -e "UPDATE auth SET secret='$SECRET' WHERE id='1';"

    log "Successfully initialized admin credentials from environment"
fi

# Create the flag file to mark completion
touch "$FLAG_FILE"

# Exit after the setup is complete
exec sleep infinity
