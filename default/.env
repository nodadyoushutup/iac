POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432:5432
POSTGRES_DATA=./postgres

DOZZLE_PORT=8085:8080

UPTIME_KUMA_DATA=./uptime-kuma
UPTIME_KUMA_PORT=3001:3001

NPM_PORT_HTTP=80:80
NPM_PORT_HTTPS=443:443
NPM_PORT_ADMIN=81:81
NPM_DATA=./nginx-proxy-manager
NPM_LETS_ENCRYPT=./letsencrypt

NODE_EXPORTER_PORT=9100:9100

CADVISOR_PORT=8080:8080

PROMETHEUS_CONFIG=./prometheus.yml
PROMTEHEUS_PORT=9090:9090
PROMTEHEUS_DATA=./prometheus_data
PROMETHEUS_TARGET_PROMETHEUS=localhost:9090

GRAFANA_PORT=3000:3000
GRAFANA_DATA=./grafana
GRAFANA_SECURITY_ADMIN_USER=grafana
GRAFANA_SECURITY_ADMIN_PASSWORD=grafana
GRAFANA_SECURITY_DISABLE_INITIAL_ADMIN_CREATION=false
GRAFANA_AUTH_ANONYMOUS_ENABLED=false
GRAFANA_AUTH_ANONYMOUS_ORG_ROLE=Admin
GRAFANA_AUTH_DISABLE_SIGNOUT_MENU=false
GRAFANA_AUTH_DISABLE_LOGIN_FORM=false

DOCKER_SOCK=/var/run/docker.sock